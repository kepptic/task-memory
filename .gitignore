# Dependencies
node_modules/
package-lock.json

# Build output
dist/

# Development files
.DS_Store
*.log
*.swp
*.swo
*~
*.bak

# IDE
.vscode/
.idea/

# User data (don't commit user's actual task files)
kanban.md
archive.md

# Environment
.env
.env.local
__pycache__/

# Build artifacts
task-memory.html

# Claude Code local settings (user-specific, not shared)
.claude/settings.local.json

# Session files (legacy location)
/tmp/task-memory-session-*.txt

# Task-memory state (counters, session task files)
.claude/state/task-memory/

# Test output
tests/output/
# tests/fixtures/ is otherwise scratch space that test-hooks.sh populates/
# tears down at runtime, EXCEPT tests/fixtures/ado/ — committed ADO sync
# fixtures (TASK-019). Use tests/fixtures/* (not a bare trailing-slash
# pattern) so the negation below can actually un-ignore that subdirectory —
# git won't descend into an excluded directory to apply negations inside it.
tests/fixtures/*
!tests/fixtures/ado
*.test.log

# Build artifacts — plugin archives
release/
dist/*.plugin

# OS files
Thumbs.db
Desktop.ini
