{
  "$schema": "./skill-rules.schema.json",
  "version": "1.0.0",
  "description": "Skill evaluation rules for task-memory plugin",

  "config": {
    "minConfidence": 3,
    "maxSkillsToShow": 3,
    "showMatchReasons": true
  },

  "triggerWeights": {
    "keyword": 3,
    "keywordPattern": 3,
    "intent": 4,
    "context": 2,
    "pathPattern": 4,
    "directoryMapping": 5,
    "exclusion": -5
  },

  "skills": {
    "task-memory": {
      "name": "task-memory",
      "description": "Task tracking with kanban board, research logging, and context preservation",
      "priority": 8,

      "keywords": [
        "implement", "build", "create", "fix", "refactor",
        "add", "update", "modify", "change", "remove",
        "develop", "design", "write", "make", "setup",
        "configure", "install", "deploy", "migrate", "upgrade",
        "debug", "investigate", "resolve", "address",
        "task", "feature", "bug", "issue", "ticket"
      ],

      "keywordPatterns": [
        "(?i)^(implement|build|create|fix|add|update|write|make|setup)\\b",
        "(?i)\\b(feature|bug|issue|task|ticket)\\b",
        "(?i)\\b(refactor|optimize|improve|enhance)\\b"
      ],

      "intentPatterns": [
        "(?i)add.*feature",
        "(?i)fix.*bug",
        "(?i)build.*component",
        "(?i)create.*function",
        "(?i)implement.*logic",
        "(?i)write.*code",
        "(?i)setup.*project",
        "(?i)refactor.*code",
        "(?i)update.*file",
        "(?i)modify.*behavior",
        "(?i)resolve.*issue",
        "(?i)address.*problem",
        "(?i)work.*on",
        "(?i)start.*working",
        "(?i)continue.*with",
        "(?i)finish.*up"
      ],

      "excludePatterns": [
        "(?i)^(what|how|why|when|where|who|which|can you|could you|would you|should)\\b",
        "(?i)\\?$",
        "(?i)^explain\\b",
        "(?i)^describe\\b",
        "(?i)^tell me\\b",
        "(?i)^show me\\b",
        "(?i)^list\\b",
        "(?i)^help me understand"
      ],

      "pathPatterns": [
        "tasks/kanban.md",
        "tasks/archive.md",
        "tasks/findings/*.md",
        "**/*.tsx",
        "**/*.ts",
        "**/*.py",
        "**/*.js",
        "src/**/*"
      ],

      "directoryMappings": {
        "tasks/": true,
        "src/": true,
        "lib/": true,
        "components/": true,
        "features/": true
      },

      "contextPatterns": [
        "(?i)in progress",
        "(?i)working on",
        "(?i)current task",
        "(?i)next step",
        "(?i)todo",
        "(?i)subtask"
      ],

      "relatedSkills": ["task-status"]
    },

    "task-status": {
      "name": "task-status",
      "description": "5-Question reboot test - verify context is solid",
      "priority": 6,

      "keywords": [
        "status", "progress", "where", "context", "current"
      ],

      "keywordPatterns": [
        "(?i)\\b(status|progress|context)\\b"
      ],

      "intentPatterns": [
        "(?i)where.*am.*i",
        "(?i)what.*working.*on",
        "(?i)current.*task",
        "(?i)check.*progress",
        "(?i)show.*status"
      ],

      "excludePatterns": [],

      "pathPatterns": [],

      "directoryMappings": {},

      "contextPatterns": [],

      "relatedSkills": ["task-memory"]
    }
  }
}
