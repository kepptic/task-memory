{
  "name": "task-memory",
  "version": "2.0.0",
  "description": "Privacy-first Kanban task manager with Manus-style memory - tasks remember your research across sessions, survive compaction, and mirror native TodoWrite",
  "author": {
    "name": "kepptic",
    "email": "kepptic@users.noreply.github.com"
  },
  "homepage": "https://github.com/kepptic/task-memory#readme",
  "repository": "https://github.com/kepptic/task-memory",
  "license": "MIT",
  "keywords": [
    "manus",
    "memory",
    "kanban",
    "tasks",
    "context-preservation",
    "todowrite",
    "precompact"
  ],
  "hooks": "./hooks/hooks.json",
  "monitors": [
    {
      "name": "task-memory-progress",
      "description": "Live in-progress task + subtask progress",
      "type": "command",
      "command": "${CLAUDE_PLUGIN_ROOT}/hooks/task-memory-hook.py",
      "refreshSeconds": 30
    }
  ]
}
